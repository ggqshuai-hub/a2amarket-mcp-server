{
  "name": "@hz-abyssal-heart/a2amarket-mcp-server",
  "version": "0.3.2",
  "description": "A2A Market MCP Server — Connect AI agents to A2A Market via Model Context Protocol",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "a2amarket-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "pack:skillhub": "node scripts/pack-skillhub.mjs",
    "pack:npm": "node scripts/pack-npm-tgz.mjs",
    "release:artifacts": "npm run build && npm run pack:npm && npm run pack:skillhub"
  },
  "keywords": [
    "mcp",
    "a2a-market",
    "agent",
    "acap",
    "procurement",
    "ai",
    "negotiation"
  ],
  "repository": {
    "type": "git",
    "url": "https://gitee.com/hz-abyssal-heart/a2amarket-mcp-server"
  },
  "author": "Abyssal Heart",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
